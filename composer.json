{
  "require": {
    "doctrine/orm": "*",
    "knplabs/github-api": "*",
    "knplabs/knp-time-bundle": "*",
    "league/commonmark": "*",
    "league/html-to-markdown": "*",
    "mpratt/embera": "*",
    "nyholm/psr7": "*",
    "symfony/expression-language": "*",
    "symfony/form": "*",
    "symfony/http-client": "*",
    "symfony/http-foundation": "*",
    "symfony/mailer": "*",
    "symfony/twig-bridge": "*",
    "twig/twig": "*"
  },
  "require-dev": {
    "symfony/messenger": "*",
    "phpunit/phpunit": "^11.0",
    "phpunit/php-invoker": "^5.0"
  },
  "autoload": {
    "psr-4": {"": "entities"}
  },
  "autoload-dev": {
    "psr-4": {"Tests\\": "tests"}
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
